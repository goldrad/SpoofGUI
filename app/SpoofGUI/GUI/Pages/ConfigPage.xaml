<Page
    x:Class="SpoofGUI.GUI.Pages.ConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:SpoofGUI.GUI.Converters"
    NavigationCacheMode="Required"
    Background="{StaticResource SurfaceBase}">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Padding="32,48,32,32" RowSpacing="24">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromVerticalOffset="16" IsStaggeringEnabled="True" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock Text="Configs" Style="{StaticResource TextCaption}" />
                <TextBlock Text="spoof profiles" Style="{StaticResource TextDisplay}" />
                <TextBlock Text="Up to 10 SNI-spoof targets. The amber profile is active; switching applies on next start."
                           Style="{StaticResource TextBodyMuted}"
                           MaxWidth="560" />
            </StackPanel>

            <Border Grid.Column="1"
                    VerticalAlignment="Top"
                    Background="{StaticResource SurfaceSunken}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20,12">
                <StackPanel Spacing="2" HorizontalAlignment="Center">
                    <TextBlock x:Name="CountText"
                               Text="01 / 10"
                               FontFamily="{StaticResource FontFamilyMono}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBase}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="profiles"
                               Style="{StaticResource TextCaption}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceSunken}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="profiles"
                                   Style="{StaticResource TextH2}"
                                   VerticalAlignment="Center" />
                        <Button x:Name="AddButton"
                                Grid.Column="1"
                                Style="{StaticResource PrimaryButton}"
                                Padding="12,6"
                                Click="OnAddProfile">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Add" Foreground="#15181E" />
                                <TextBlock Text="new" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <ListView x:Name="ProfileList"
                              Grid.Row="1"
                              SelectionMode="Single"
                              SelectionChanged="OnProfileSelected"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.Resources>
                            <SolidColorBrush x:Key="ListViewItemBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="#23272F" />
                            <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#2A2F3A" />
                            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#2F343F" />
                            <SolidColorBrush x:Key="ListViewItemSelectionIndicatorBrush" Color="Transparent" />
                        </ListView.Resources>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="CornerRadius" Value="8" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemContainerTransitions>
                            <TransitionCollection>
                                <AddDeleteThemeTransition />
                                <ContentThemeTransition />
                                <ReorderThemeTransition />
                            </TransitionCollection>
                        </ListView.ItemContainerTransitions>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8"
                                        Padding="12,11"
                                        Background="{StaticResource SurfaceRaised}"
                                        BorderBrush="{StaticResource BorderSubtle}"
                                        BorderThickness="1">
                                    <Grid ColumnSpacing="11">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="3"
                                                CornerRadius="2"
                                                Background="{StaticResource AccentBase}"
                                                Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}" />
                                        <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       Style="{StaticResource TextBody}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Target}"
                                                       Style="{StaticResource TextMono}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Border Grid.Column="2"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource AccentBase}"
                                                CornerRadius="{StaticResource RadiusSm}"
                                                Padding="10,3"
                                                Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="active"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="#15181E" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceRaised}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28">
                    <StackPanel Spacing="22">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock x:Name="EditorTitle" Text="profile" Style="{StaticResource TextH1}" />
                                <TextBlock Text="Edits apply on next listener start."
                                           Style="{StaticResource TextCaption}" />
                            </StackPanel>
                            <Border x:Name="EditorActiveBadge"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource AccentBase}"
                                    CornerRadius="{StaticResource RadiusSm}"
                                    Padding="12,5"
                                    Visibility="Collapsed">
                                <TextBlock Text="active profile"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#15181E" />
                            </Border>
                        </Grid>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Profile name" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="NameBox" Style="{StaticResource FieldTextBox}" FontFamily="{StaticResource FontFamilyUI}" />
                        </StackPanel>

                        <StackPanel Spacing="12">
                            <TextBlock Text="Local listener" Style="{StaticResource TextH2}" />
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Text="Listen Host" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="ListenHost" Style="{StaticResource FieldTextBox}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Listen Port" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="ListenPort" Style="{StaticResource FieldTextBox}" InputScope="Number" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="12">
                            <TextBlock Text="Remote target" Style="{StaticResource TextH2}" />
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Text="Connect IP" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="ConnectIp" Style="{StaticResource FieldTextBox}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Connect Port" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="ConnectPort" Style="{StaticResource FieldTextBox}" InputScope="Number" />
                                </StackPanel>
                            </Grid>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Fake SNI" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="FakeSni" Style="{StaticResource FieldTextBox}" />
                                <TextBlock Text="Hostname the DPI middlebox sees in the injected ClientHello."
                                           Style="{StaticResource TextCaption}" />
                            </StackPanel>
                        </StackPanel>

                        <Border Style="{StaticResource SectionDivider}" Margin="0" />

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="DeleteButton"
                                    Grid.Column="0"
                                    Style="{StaticResource DangerButton}"
                                    Click="OnDelete">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Delete" Foreground="{StaticResource StatusDanger}" />
                                    <TextBlock Text="delete" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="SetActiveButton"
                                    Grid.Column="2"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="OnSetActive">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Accept" Foreground="{StaticResource AccentBase}" />
                                    <TextBlock Text="set active" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="RevertButton"
                                    Grid.Column="3"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="OnRevert">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Undo" Foreground="{StaticResource TextPrimary}" />
                                    <TextBlock Text="revert" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="SaveButton"
                                    Grid.Column="4"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="OnSave">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Save" Foreground="#15181E" />
                                    <TextBlock Text="save" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock x:Name="StatusText"
                                   Style="{StaticResource TextCaption}"
                                   Foreground="{StaticResource TextSecondary}"
                                   Text="" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
